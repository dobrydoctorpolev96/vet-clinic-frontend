{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2015",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./js",
    "rootDir": "./ts",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "removeComments": true,
    "noEmitOnError": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["ts/**/*"],
  "exclude": ["node_modules", "js", "**/*.spec.ts"]
}
